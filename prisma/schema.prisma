generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  plan         String   @default("free")
  featureFlags Json     @default("{}")
  settings     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users           User[]
  events          Event[]
  subscriptions   Subscription[]
  invoices        Invoice[]
  transactions    Transaction[]
  referrals       Referral[]       @relation("Referrer")
  referredBy      Referral[]       @relation("Referred")
  analyticsEvents AnalyticsEvent[]
  auditLogs       AuditLog[]
  storageUsage    StorageUsage[]
  invitations     OrganizationInvitation[] @relation("Invitations")
  watermarks      Watermark[]      @relation("Watermarks")
  customDomains   CustomDomain[]   @relation("CustomDomains")
  supportTickets  SupportTicket[]  @relation("SupportTickets")
  couponRedemptions CouponRedemption[] @relation("CouponRedemptions")
  faceSearchLogs  FaceSearchLog[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  email          String   @unique
  fullName       String?  @map("full_name")
  avatarUrl      String?  @map("avatar_url")
  role           String   @default("member")
  isAdmin        Boolean  @default(false) @map("is_admin")
  permissions    Json     @default("[]")
  preferences    Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization?   @relation(fields: [organizationId], references: [id])
  hostedEvents   Event[]         @relation("EventHost")
  photos         Photo[]
  faceSearchLogs FaceSearchLog[]
  auditLogs      AuditLog[]

  @@map("users")
}

model Event {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  hostId         String?   @map("host_id")
  name           String
  slug           String
  description    String?
  eventType      String?   @map("event_type")
  eventDate      DateTime? @map("event_date")
  endDate        DateTime? @map("end_date")
  venue          String?
  timezone       String    @default("UTC")
  coverImageUrl  String?   @map("cover_image_url")
  settings       Json      @default("{}")
  status         String    @default("draft")
  viewCount      Int       @default(0) @map("view_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id])
  host          User?         @relation("EventHost", fields: [hostId], references: [id])
  galleries     Gallery[]
  qrCodes       QrCode[]
  qrScans       QrScan[]
  photos        Photo[]
  photoAccesses PhotoAccess[]
  faces         Face[]
  faceClusters  FaceCluster[]
  liveWallItems LiveWallItem[]
  slideshows    Slideshow[]
  downloadBundles DownloadBundle[]

  @@unique([organizationId, slug])
  @@map("events")
}

model Gallery {
  id            String    @id @default(uuid())
  eventId       String    @map("event_id")
  name          String
  slug          String
  description   String?
  coverImageUrl String?   @map("cover_image_url")
  isPublic      Boolean   @default(true) @map("is_public")
  revealAt      DateTime? @map("reveal_at")
  revealEnabled Boolean   @default(false) @map("reveal_enabled")
  settings      Json      @default("{}")
  photoCount    Int       @default(0) @map("photo_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photos        Photo[]
  qrCodes       QrCode[]
  photoAccesses PhotoAccess[]

  @@unique([eventId, slug])
  @@map("galleries")
}

model Photo {
  id               String   @id @default(uuid())
  galleryId        String   @map("gallery_id")
  uploaderId       String?  @map("uploader_id")
  eventId          String   @map("event_id")
  storagePath      String   @map("storage_path")
  thumbnailPath    String?  @map("thumbnail_path")
  originalFilename String?  @map("original_filename")
  mimeType         String?  @map("mime_type")
  fileSize         Int?     @map("file_size")
  width            Int?
  height           Int?
  metadata         Json     @default("{}")
  isApproved       Boolean  @default(false) @map("is_approved")
  isFeatured       Boolean  @default(false) @map("is_featured")
  faceCount        Int      @default(0) @map("face_count")
  downloadCount    Int      @default(0) @map("download_count")
  createdAt        DateTime @default(now()) @map("created_at")

  gallery           Gallery         @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  uploader          User?           @relation(fields: [uploaderId], references: [id])
  event             Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  faces             Face[]
  faceSearchQueries FaceSearchLog[] @relation("FaceSearchQuery")
  faceSearchResults FaceSearchLog[] @relation("FaceSearchResults")

  @@map("photos")
}

model QrCode {
  id          String    @id @default(uuid())
  eventId     String    @map("event_id")
  galleryId   String?   @map("gallery_id")
  code        String    @unique
  name        String?
  redirectUrl String?   @map("redirect_url")
  scanCount   Int       @default(0) @map("scan_count")
  settings    Json      @default("{}")
  isActive    Boolean   @default(true) @map("is_active")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  gallery Gallery? @relation(fields: [galleryId], references: [id])

  @@map("qr_codes")
}

model PhotoAccess {
  id           String    @id @default(uuid())
  eventId      String    @map("event_id")
  galleryId    String?   @map("gallery_id")
  sessionToken String    @unique @map("session_token")
  guestName    String?   @map("guest_name")
  guestEmail   String?   @map("guest_email")
  permissions  Json      @default("[]")
  accessedAt   DateTime  @default(now()) @map("accessed_at")
  expiresAt    DateTime? @map("expires_at")

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  gallery Gallery? @relation(fields: [galleryId], references: [id])

  @@map("photo_access")
}

model Plan {
  id              String   @id
  name            String
  description     String?
  priceInr        Int      @map("price_inr")
  priceUsd        Int      @map("price_usd")
  billingInterval String   @default("monthly") @map("billing_interval")
  features        Json     @default("[]")
  limits          Json     @default("{}")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                     String    @id @default(uuid())
  organizationId         String    @map("organization_id")
  planId                 String    @map("plan_id")
  razorpaySubscriptionId String?   @unique @map("razorpay_subscription_id")
  razorpayCustomerId     String?   @map("razorpay_customer_id")
  status                 String    @default("active")
  currentPeriodStart     DateTime? @map("current_period_start")
  currentPeriodEnd       DateTime? @map("current_period_end")
  trialEndsAt            DateTime? @map("trial_ends_at")
  cancelAtPeriodEnd      Boolean   @default(false) @map("cancel_at_period_end")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  plan         Plan         @relation(fields: [planId], references: [id])
  invoices     Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id                String    @id @default(uuid())
  organizationId    String    @map("organization_id")
  subscriptionId    String?   @map("subscription_id")
  razorpayInvoiceId String?   @unique @map("razorpay_invoice_id")
  invoiceNumber     String    @map("invoice_number")
  status            String    @default("created")
  currency          String    @default("INR")
  subtotal          Int
  tax               Int       @default(0)
  total             Int
  paidAt            DateTime? @map("paid_at")
  issuedAt          DateTime  @default(now()) @map("issued_at")
  dueAt             DateTime? @map("due_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  transactions Transaction[]

  @@map("invoices")
}

model Transaction {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  invoiceId         String?  @map("invoice_id")
  razorpayPaymentId String?  @unique @map("razorpay_payment_id")
  razorpayOrderId   String?  @map("razorpay_order_id")
  amount            Int
  currency          String   @default("INR")
  status            String   @default("pending")
  paymentMethod     String?  @map("payment_method")
  errorCode         String?  @map("error_code")
  errorDescription  String?  @map("error_description")
  gatewayResponse   Json?    @map("gateway_response")
  createdAt         DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])

  @@map("transactions")
}

model Coupon {
  id                    String    @id @default(uuid())
  code                  String    @unique
  discountType          String    @map("discount_type")
  discountValue         Int       @map("discount_value")
  minSubscriptionMonths Int       @default(1) @map("min_subscription_months")
  maxUses               Int?      @map("max_uses")
  usedCount             Int       @default(0) @map("used_count")
  validFrom             DateTime  @default(now()) @map("valid_from")
  validUntil            DateTime? @map("valid_until")
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at")

  referrals Referral[]
  redemptions CouponRedemption[]

  @@map("coupons")
}

model Referral {
  id             String   @id @default(uuid())
  referrerOrgId  String   @map("referrer_org_id")
  referredOrgId  String   @map("referred_org_id")
  couponId       String?  @map("coupon_id")
  status         String   @default("pending")
  rewardCredited Boolean  @default(false) @map("reward_credited")
  createdAt      DateTime @default(now()) @map("created_at")

  referrerOrg Organization @relation("Referrer", fields: [referrerOrgId], references: [id])
  referredOrg Organization @relation("Referred", fields: [referredOrgId], references: [id])
  coupon      Coupon?      @relation(fields: [couponId], references: [id])

  @@map("referrals")
}

model Face {
  id            String   @id @default(uuid())
  eventId       String   @map("event_id")
  photoId       String   @map("photo_id")
  boundingBox   Json     @map("bounding_box")
  confidence    Float
  embeddingPath String?  @map("embedding_path")
  createdAt     DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@map("faces")
}

model FaceSearchLog {
  id               String   @id @default(uuid())
  organizationId   String?  @map("organization_id")
  userId           String?  @map("user_id")
  searchType       String   @map("search_type")
  queryPhotoId     String?  @map("query_photo_id")
  results          Json     @default("[]")
  searchDurationMs Int?     @map("search_duration_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  user         User?   @relation(fields: [userId], references: [id])
  queryPhoto   Photo?  @relation("FaceSearchQuery", fields: [queryPhotoId], references: [id])
  resultPhotos Photo[] @relation("FaceSearchResults")

  @@map("face_search_logs")
}

model AnalyticsEvent {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  eventType      String   @map("event_type")
  eventData      Json     @default("{}") @map("event_data")
  userId         String?
  sessionId      String?  @map("session_id")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("analytics_events")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  userId         String?
  action         String
  resourceType   String   @map("resource_type")
  resourceId     String?  @map("resource_id")
  changes        Json?    @map("changes")
  ipAddress      String?  @map("ip_address")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model StorageUsage {
  id             String   @id @default(uuid())
  organizationId String   @unique @map("organization_id")
  totalBytes     BigInt   @default(0) @map("total_bytes")
  photoCount     Int      @default(0) @map("photo_count")
  updatedAt      DateTime @default(now()) @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("storage_usage")
}

model WebhookEvent {
  id           String   @id @default(uuid())
  source       String
  eventType    String   @map("event_type")
  externalId   String?  @map("external_id")
  payload      Json
  processed    Boolean  @default(false)
  processedAt  DateTime? @map("processed_at")
  error        String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("webhook_events")
}

model OrganizationInvitation {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  email          String
  role           String   @default("member")
  token          String   @unique
  acceptedAt     DateTime? @map("accepted_at")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation("Invitations", fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_invitations")
}

model QrScan {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  qrCodeId  String?  @map("qr_code_id")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  referer   String?
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("qr_scans")
}

model CouponRedemption {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  couponId       String   @map("coupon_id")
  discountAmount Int      @map("discount_amount")
  redemptionDate DateTime @default(now()) @map("redemption_date")

  organization Organization @relation("CouponRedemptions", fields: [organizationId], references: [id])
  coupon       Coupon       @relation(fields: [couponId], references: [id])

  @@unique([organizationId, couponId])
  @@map("coupon_redemptions")
}

model FaceCluster {
  id            String   @id @default(uuid())
  eventId       String   @map("event_id")
  name          String?
  representativeFaceId String? @map("representative_face_id")
  description   String?
  faceCount     Int      @default(0) @map("face_count")
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("face_clusters")
}

model LiveWallItem {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  photoId   String   @map("photo_id")
  order     Int
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("live_wall_items")
}

model Slideshow {
  id         String    @id @default(uuid())
  eventId    String    @map("event_id")
  name       String
  settings   Json      @default("{}")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("slideshows")
}

model Watermark {
  id         String    @id @default(uuid())
  organizationId String @map("organization_id")
  name       String
  imageUrl   String    @map("image_url")
  position   String    @default("bottom_right")
  opacity    Float     @default(0.5)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")

  organization Organization @relation("Watermarks", fields: [organizationId], references: [id])

  @@map("watermarks")
}

model CustomDomain {
  id         String    @id @default(uuid())
  organizationId String @map("organization_id")
  domain     String    @unique
  isVerified Boolean   @default(false) @map("is_verified")
  createdAt  DateTime  @default(now()) @map("created_at")

  organization Organization @relation("CustomDomains", fields: [organizationId], references: [id])

  @@map("custom_domains")
}

model SupportTicket {
  id              String   @id @default(uuid())
  organizationId  String?  @map("organization_id")
  subject         String
  description     String
  status          String   @default("open")
  priority        String   @default("normal")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization? @relation("SupportTickets", fields: [organizationId], references: [id])
  messages       SupportTicketMessage[]

  @@map("support_tickets")
}

model SupportTicketMessage {
  id       String   @id @default(uuid())
  ticketId String   @map("ticket_id")
  message  String
  author   String
  createdAt DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("support_ticket_messages")
}

model DownloadBundle {
  id         String   @id @default(uuid())
  eventId    String   @map("event_id")
  galleryId  String?  @map("gallery_id")
  title      String
  status     String   @default("pending")
  zipUrl     String?  @map("zip_url")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("download_bundles")
}

model AiUsage {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  feature        String
  tokensUsed     Int      @map("tokens_used")
  costUsd        Float    @map("cost_usd")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ai_usage")
}

model PlatformSettings {
  id    String @id @default(uuid())
  key   String @unique
  value Json

  @@map("platform_settings")
}

model NotificationQueue {
  id           String   @id @default(uuid())
  organizationId String? @map("organization_id")
  type         String
  recipient    String
  payload      Json
  status       String   @default("pending")
  retryCount   Int      @default(0) @map("retry_count")
  lastError    String?  @map("last_error")
  scheduledFor DateTime @default(now()) @map("scheduled_for")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("notification_queue")
}

model EmailTemplate {
  id          String   @id
  name        String
  subject     String
  htmlContent String   @map("html_content")
  textContent String?  @map("text_content")
  variables   String[]
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

model EmailLog {
  id           String    @id @default(uuid())
  recipient    String
  subject      String
  emailType    String    @map("email_type")
  status       String    @default("pending")
  resendId     String?   @map("resend_id")
  errorMessage String?   @map("error_message")
  retryCount   Int       @default(0) @map("retry_count")
  openedAt     DateTime? @map("opened_at")
  clickedAt    DateTime? @map("clicked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("email_logs")
}
