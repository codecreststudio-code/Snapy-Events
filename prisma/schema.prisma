generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  plan         String   @default("free")
  featureFlags Json     @default("{}")
  settings     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users           User[]
  events          Event[]
  subscriptions   Subscription[]
  invoices        Invoice[]
  transactions    Transaction[]
  referrals       Referral[]       @relation("Referrer")
  referredBy     Referral[]       @relation("Referred")
  analyticsEvents AnalyticsEvent[]
  auditLogs       AuditLog[]
  storageUsage    StorageUsage[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  email          String   @unique
  fullName       String?  @map("full_name")
  avatarUrl      String?  @map("avatar_url")
  role           String   @default("member")
  permissions    Json     @default("[]")
  preferences    Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization? @relation(fields: [organizationId], references: [id])
  hostedEvents   Event[]      @relation("EventHost")
  photos         Photo[]
  faceSearchLogs FaceSearchLog[]
  auditLogs      AuditLog[]

  @@map("users")
}

model Event {
  id             String   @id @default(uuid())
  organizationId String  @map("organization_id")
  hostId          String?  @map("host_id")
  name           String
  slug           String
  description     String?
  eventType      String?  @map("event_type")
  eventDate      DateTime? @map("event_date")
  endDate        DateTime? @map("end_date")
  venue          String?
  timezone       String   @default("UTC")
  coverImageUrl  String?  @map("cover_image_url")
  settings       Json     @default("{}")
  status         String   @default("draft")
  viewCount      Int      @default(0) @map("view_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  host         User?        @relation("EventHost", fields: [hostId], references: [id])
  galleries    Gallery[]
  qrCodes      QrCode[]
  photos       Photo[]

  @@unique([organizationId, slug])
  @@map("events")
}

model Gallery {
  id              String   @id @default(uuid())
  eventId         String   @map("event_id")
  name            String
  slug            String
  description     String?
  coverImageUrl   String?  @map("cover_image_url")
  isPublic        Boolean  @default(true) @map("is_public")
  revealAt        DateTime? @map("reveal_at")
  revealEnabled   Boolean  @default(false) @map("reveal_enabled")
  settings        Json     @default("{}")
  photoCount      Int       @default(0) @map("photo_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  event Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photos Photo[]

  @@unique([eventId, slug])
  @@map("galleries")
}

model Photo {
  id              String   @id @default(uuid())
  galleryId       String   @map("gallery_id")
  uploaderId      String?  @map("uploader_id")
  eventId         String   @map("event_id")
  storagePath     String   @map("storage_path")
  thumbnailPath   String?  @map("thumbnail_path")
  originalFilename String? @map("original_filename")
  mimeType        String?  @map("mime_type")
  fileSize        Int?     @map("file_size")
  width           Int?
  height          Int?
  metadata        Json     @default("{}")
  isApproved      Boolean  @default(false) @map("is_approved")
  isFeatured      Boolean  @default(false) @map("is_featured")
  faceCount       Int       @default(0) @map("face_count")
  downloadCount   Int       @default(0) @map("download_count")
  createdAt       DateTime  @default(now()) @map("created_at")

  gallery Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  uploader User?   @relation(fields: [uploaderId], references: [id])
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  faces    Face[]

  @@map("photos")
}

model QrCode {
  id          String    @id @default(uuid())
  eventId     String    @map("event_id")
  galleryId   String?   @map("gallery_id")
  code        String    @unique
  name        String?
  redirectUrl String?   @map("redirect_url")
  scanCount   Int       @default(0) @map("scan_count")
  settings    Json      @default("{}")
  isActive    Boolean   @default(true) @map("is_active")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  gallery Gallery? @relation(fields: [galleryId], references: [id])

  @@map("qr_codes")
}

model PhotoAccess {
  id           String    @id @default(uuid())
  eventId      String    @map("event_id")
  galleryId    String?   @map("gallery_id")
  sessionToken String    @unique @map("session_token")
  guestName    String?   @map("guest_name")
  guestEmail   String?   @map("guest_email")
  permissions  Json      @default("[]")
  accessedAt   DateTime  @default(now()) @map("accessed_at")
  expiresAt    DateTime? @map("expires_at")

  event  Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  gallery Gallery? @relation(fields: [galleryId], references: [id])

  @@map("photo_access")
}

model Plan {
  id              String   @id
  name            String
  description     String?
  priceInr        Int      @map("price_inr")
  priceUsd        Int      @map("price_usd")
  billingInterval String   @default("monthly") @map("billing_interval")
  features        Json     @default("[]")
  limits          Json     @default("{}")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                     String    @id @default(uuid())
  organizationId         String    @map("organization_id")
  planId                  String    @map("plan_id")
  razorpaySubscriptionId  String?   @unique @map("razorpay_subscription_id")
  razorpayCustomerId     String?   @map("razorpay_customer_id")
  status                  String    @default("active")
  currentPeriodStart     DateTime? @map("current_period_start")
  currentPeriodEnd        DateTime? @map("current_period_end")
  trialEndsAt             DateTime? @map("trial_ends_at")
  cancelAtPeriodEnd       Boolean   @default(false) @map("cancel_at_period_end")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  plan         Plan         @relation(fields: [planId], references: [id])
  invoices     Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  subscriptionId  String?   @map("subscription_id")
  razorpayInvoiceId String? @unique @map("razorpay_invoice_id")
  invoiceNumber   String    @map("invoice_number")
  status          String    @default("created")
  currency        String    @default("INR")
  subtotal        Int
  tax             Int        @default(0)
  total           Int
  paidAt          DateTime? @map("paid_at")
  issuedAt        DateTime  @default(now()) @map("issued_at")
  dueAt           DateTime? @map("due_at")

  organization Organization   @relation(fields: [organizationId], references: [id])
  subscription Subscription?  @relation(fields: [subscriptionId], references: [id])
  transactions  Transaction[]

  @@map("invoices")
}

model Transaction {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  invoiceId       String?   @map("invoice_id")
  razorpayPaymentId String? @unique @map("razorpay_payment_id")
  razorpayOrderId String?   @map("razorpay_order_id")
  amount          Int
  currency        String    @default("INR")
  status          String    @default("pending")
  paymentMethod   String?   @map("payment_method")
  gatewayResponse Json?     @map("gateway_response")
  createdAt       DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id])

  @@map("transactions")
}

model Coupon {
  id                   String    @id @default(uuid())
  code                 String    @unique
  discountType         String    @map("discount_type")
  discountValue        Int       @map("discount_value")
  minSubscriptionMonths Int     @default(1) @map("min_subscription_months")
  maxUses              Int?      @map("max_uses")
  usedCount            Int       @default(0) @map("used_count")
  validFrom            DateTime  @default(now()) @map("valid_from")
  validUntil           DateTime? @map("valid_until")
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at")

  referrals Referral[]

  @@map("coupons")
}

model Referral {
  id             String    @id @default(uuid())
  referrerOrgId  String    @map("referrer_org_id")
  referredOrgId   String    @map("referred_org_id")
  couponId       String?   @map("coupon_id")
  status         String    @default("pending")
  rewardCredited Boolean   @default(false) @map("reward_credited")
  createdAt      DateTime  @default(now()) @map("created_at")

  referrerOrg Organization @relation("Referrer", fields: [referrerOrgId], references: [id])
  referredOrg  Organization @relation("Referred", fields: [referredOrgId], references: [id])
  coupon      Coupon?       @relation(fields: [couponId], references: [id])

  @@map("referrals")
}

model Face {
  id           String   @id @default(uuid())
  photoId      String   @map("photo_id")
  boundingBox  Json     @map("bounding_box")
  confidence   Float
  embeddingPath String? @map("embedding_path")
  createdAt    DateTime @default(now()) @map("created_at")

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@map("faces")
}

model FaceSearchLog {
  id                String   @id @default(uuid())
  userId            String?  @map("user_id")
  searchType        String   @map("search_type")
  queryPhotoId      String?  @map("query_photo_id")
  results           Json     @default("[]")
  searchDurationMs  Int?     @map("search_duration_ms")
  createdAt         DateTime @default(now()) @map("created_at")

  user       User?   @relation(fields: [userId], references: [id])
  queryPhoto Photo?  @relation("FaceSearchQuery", fields: [queryPhotoId], references: [id])
  resultPhotos Photo[] @relation("FaceSearchResults")

  @@map("face_search_logs")
}

model AnalyticsEvent {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  eventType      String    @map("event_type")
  eventData      Json      @default("{}") @map("event_data")
  userId         String?
  sessionId      String?   @map("session_id")
  ipAddress      String?   @map("ip_address")
  userAgent      String?   @map("user_agent")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("analytics_events")
}

model AuditLog {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  userId         String?
  action         String
  resourceType   String    @map("resource_type")
  resourceId     String?   @map("resource_id")
  changes        Json?     @map("changes")
  ipAddress      String?   @map("ip_address")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  user        User?          @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model StorageUsage {
  id             String   @id @default(uuid())
  organizationId String   @unique @map("organization_id")
  totalBytes     BigInt   @default(0) @map("total_bytes")
  photoCount     Int      @default(0) @map("photo_count")
  updatedAt      DateTime @default(now()) @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("storage_usage")
}