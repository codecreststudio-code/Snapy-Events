# Supabase Connection (PostgreSQL via Supabase)
# Get these from your Supabase project settings > Connection Pooling
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Auth Keys
# Get from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================================
# ADMIN CREDENTIALS
# ============================================================
# SECURITY: NEVER hardcode these. Set via environment variables only.
# ADMIN_EMAIL must be a real user in your Supabase Auth with is_admin=true.
# ADMIN_PASSWORD must be >= 12 characters, complex.
# Generate CSRF_SECRET: openssl rand -hex 32
ADMIN_EMAIL="your-admin@yourdomain.com"
ADMIN_PASSWORD="YourStrongPassword123!" 
CSRF_SECRET="your-random-64-character-hex-secret-generated-with-openssl-rand-hex-32"

# Razorpay Payment Gateway
# Get from: Razorpay Dashboard > Settings > API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxx"   # Public key (safe to expose to browser)
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxx"               # Server-side copy
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"       # NEVER expose to frontend
RAZORPAY_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# WhatsApp Business API (Optional)
WHATSAPP_BUSINESS_API_KEY="your-whatsapp-api-key"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-business-account-id"

# Email (Resend)
# Get from: Resend.com > API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# NOTE: RESEND_FROM_EMAIL is not read by the app — the sender address is
# configured live in Admin > Email Management > Settings ("Sender Email"),
# stored in platform_settings, so it can be changed without redeploying.
# Whatever address you set there MUST be on a domain verified at
# resend.com/domains — a webmail domain (gmail.com, yahoo.com, etc.) will
# always be rejected. Use onboarding@resend.dev for testing before you have
# a verified domain.
# Required to verify inbound Resend (Svix) webhooks — without it /api/emails/webhook returns 503.
# Get from: Resend Dashboard > Webhooks > Signing Secret. Note it starts with
# the prefix "whsec_" (shared with Stripe's webhook secret format) — the
# placeholder below is deliberately NOT in that exact shape, since GitHub's
# secret scanner pattern-matches on "whsec_" + a long token and flagged this
# line as a "Stripe Webhook Signing Secret" leak even though this file only
# ever contained a placeholder, never a real value.
RESEND_WEBHOOK_SECRET="paste-your-resend-webhook-signing-secret-here"

# AI Face Recognition
# Not needed. Face detection runs locally for free via face-api.js
# (TensorFlow.js WASM backend) — see src/lib/integrations/face.ts.
# These vars are unused and kept only in case you swap in a paid provider later.
FACE_API_KEY=""
FACE_API_URL=""

# OpenAI (Optional - for blog assistant)
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Sentry Error Tracking (Optional)
SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxx"

# Microsoft Clarity Heatmaps & Session Analytics (Optional)
NEXT_PUBLIC_CLARITY_PROJECT_ID="Project_ID_Key"

# Upstash Redis (Required for production rate limiting)
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Firebase Cloud Messaging (push notifications)
# Public web config — get from Firebase Console > Project Settings > General
# > Your apps > Web app. public/sw.js fetches this config dynamically via /api/firebase-config.
NEXT_PUBLIC_FIREBASE_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="xxxxxxxxxxxx"
NEXT_PUBLIC_FIREBASE_APP_ID="1:xxxxxxxxxxxx:web:xxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"
# Firebase Console > Project Settings > Cloud Messaging > Web configuration
# > Web Push certificates.
NEXT_PUBLIC_FIREBASE_VAPID_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# SERVER-SIDE ONLY. Firebase Console > Project Settings > Service Accounts >
# Generate new private key — paste the whole downloaded JSON as one line.
# Never expose this with NEXT_PUBLIC_. Required for the backend to actually
# send pushes via firebase-admin; sending no-ops with a log warning without it.
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Application URL
NEXT_PUBLIC_APP_URL="https://snapsy-events.vercel.app"
APP_URL="https://snapsy-events.vercel.app"

# Node Environment
NODE_ENV="production"
